# =============================================================
# .gitignore — House Price Prediction
# =============================================================
 
# ---------------------------------------------------------------
# Python virtual environment — NEVER commit this
# Can be 200MB+. Anyone cloning installs their own via requirements.txt
# ---------------------------------------------------------------
venv/
env/
.env/
.venv/
 
# ---------------------------------------------------------------
# Python cache — auto-generated, not needed in git
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
 
# ---------------------------------------------------------------
# Jupyter checkpoints — auto-save clutter
# ---------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
 
# ---------------------------------------------------------------
# Data files — download directly from Kaggle
# Raw and cleaned CSVs are regenerated by Notebook 01
# ---------------------------------------------------------------
data/housing.csv
data/housing_clean.csv
data/*.csv
 
# ---------------------------------------------------------------
# macOS system files — never commit these
# ---------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
**/.DS_Store
 
# ---------------------------------------------------------------
# Environment variable files — NEVER commit secrets
# ---------------------------------------------------------------
.env
*.env
.env.local
.env.*.local
 
# ---------------------------------------------------------------
# Editor config
# ---------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
 
# ---------------------------------------------------------------
# Logs and temp files
# ---------------------------------------------------------------
*.log
*.tmp
*.temp
 
# ---------------------------------------------------------------
# NOTE: models/*.pkl and outputs/*.png ARE committed intentionally
# They are small enough (<100MB) and make the repo usable
# without having to retrain everything from scratch
# ---------------------------------------------------------------